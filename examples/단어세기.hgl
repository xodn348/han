변수 텍스트 = "hello world hello han world hello programming world"
변수 단어들 = 텍스트.분리(" ")
변수 빈도 = 사전()

반복 단어 안에서 단어들 {
    시도 {
        변수 현재 = 빈도[단어]
        빈도[단어] = 현재 + 1
    } 실패(오류) {
        빈도[단어] = 1
    }
}

출력("=== 단어 빈도 ===")
변수 키들 = 빈도.키목록()
반복 키 안에서 키들 {
    출력(형식("{0}: {1}회", 키, 빈도[키]))
}
