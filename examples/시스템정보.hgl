출력("=== 시스템 정보 ===")
출력(형식("현재 시간: {0}", 현재시간()))
출력(형식("현재 날짜: {0}", 현재날짜()))

시도 {
    변수 사용자 = 실행("whoami")
    출력(형식("사용자: {0}", 사용자.앞뒤공백제거()))

    변수 운영체제 = 실행("uname -s")
    출력(형식("운영체제: {0}", 운영체제.앞뒤공백제거()))

    변수 디렉토리 = 실행("pwd")
    출력(형식("현재 디렉토리: {0}", 디렉토리.앞뒤공백제거()))
} 실패(오류) {
    출력(형식("시스템 명령 오류: {0}", 오류))
}
