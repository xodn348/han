구조 사각형 {
    너비: 정수,
    높이: 정수
}

구현 사각형 {
    함수 넓이(자신: 사각형) -> 정수 {
        반환 자신.너비 * 자신.높이
    }

    함수 둘레(자신: 사각형) -> 정수 {
        반환 (자신.너비 + 자신.높이) * 2
    }

    함수 정사각형인가(자신: 사각형) -> 불 {
        반환 자신.너비 == 자신.높이
    }
}

변수 도형들 = [
    사각형 { 너비: 5, 높이: 3 },
    사각형 { 너비: 4, 높이: 4 },
    사각형 { 너비: 10, 높이: 2 }
]

반복 도형 안에서 도형들 {
    출력(형식("{0}x{1} → 넓이: {2}, 둘레: {3}, 정사각형: {4}",
        도형.너비, 도형.높이, 도형.넓이(), 도형.둘레(), 도형.정사각형인가()))
}
