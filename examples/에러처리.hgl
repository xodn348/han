함수 안전나누기(a: 정수, b: 정수) -> 문자열 {
    시도 {
        변수 결과 = a / b
        반환 형식("{0} / {1} = {2}", a, b, 결과)
    } 실패(오류) {
        반환 형식("{0} / {1} → 오류: {2}", a, b, 오류)
    }
}

출력(안전나누기(10, 3))
출력(안전나누기(10, 0))

출력("\n=== 파일 에러 처리 ===")
시도 {
    변수 내용 = 파일읽기("/없는/경로/파일.txt")
    출력(내용)
} 실패(오류) {
    출력(형식("파일 오류: {0}", 오류))
}

출력("\n=== 인덱스 에러 처리 ===")
시도 {
    변수 배열 = [1, 2, 3]
    출력(배열[99])
} 실패(오류) {
    출력(형식("인덱스 오류: {0}", 오류))
}
