변수 파일경로 = "/tmp/han_test_data.csv"

파일쓰기(파일경로, "이름,나이,도시\n홍길동,30,서울\n김철수,25,부산\n이영희,35,서울\n박지민,28,대전\n")

변수 내용 = 파일읽기(파일경로)
변수 줄들 = 내용.분리("\n")

출력("=== CSV 파싱 ===")
변수 헤더 = 줄들[0].분리(",")
출력(형식("컬럼: {0}", 헤더.합치기(" | ")))

출력("\n=== 데이터 ===")
반복 i 안에서 1..줄들.길이() {
    만약 줄들[i].길이() > 0 {
        변수 필드 = 줄들[i].분리(",")
        출력(형식("{0} - {1}세, {2} 거주", 필드[0], 필드[1], 필드[2]))
    }
}
