변수 사용자들 = [
    사전("이름", "홍길동", "나이", 30, "도시", "서울"),
    사전("이름", "김철수", "나이", 25, "도시", "부산"),
    사전("이름", "이영희", "나이", 35, "도시", "서울")
]

출력("=== 서울 거주자 ===")
반복 사용자 안에서 사용자들 {
    만약 사용자["도시"] == "서울" {
        출력(형식("{0} ({1}세)", 사용자["이름"], 사용자["나이"]))
    }
}

출력("\n=== JSON 출력 ===")
반복 사용자 안에서 사용자들 {
    출력(제이슨_생성(사용자))
}
