// 가위바위보 결과 판정

함수 판정(플레이어: 정수, 컴퓨터: 정수) -> 문자열 {
    플레이어 == 컴퓨터 만약 { 반환 "무승부" }

    맞춤 플레이어 {
        0 => {
            컴퓨터 == 2 만약 { 반환 "승리" }
            반환 "패배"
        }
        1 => {
            컴퓨터 == 0 만약 { 반환 "승리" }
            반환 "패배"
        }
        2 => {
            컴퓨터 == 1 만약 { 반환 "승리" }
            반환 "패배"
        }
        _ => { 반환 "오류" }
    }
}

// 0=가위, 1=바위, 2=보
출력(형식("가위 vs 보 = {0}", 판정(0, 2)))
출력(형식("바위 vs 가위 = {0}", 판정(1, 0)))
출력(형식("보 vs 보 = {0}", 판정(2, 2)))
