함수 적용(f: 함수, x: 정수) -> 정수 {
    반환 f(x)
}

변수 두배 = 함수(x: 정수) { 반환 x * 2 }
변수 제곱 = 함수(x: 정수) { 반환 x * x }
변수 음수 = 함수(x: 정수) { 반환 -x }

변수 숫자들 = [1, 2, 3, 4, 5]

출력("원본:")
출력(숫자들)

출력("두배:")
변수 결과 = []
반복 n 안에서 숫자들 {
    결과.추가(적용(두배, n))
}
출력(결과)

출력("제곱:")
변수 결과2 = []
반복 n 안에서 숫자들 {
    결과2.추가(적용(제곱, n))
}
출력(결과2)

변수 배수 = 3
변수 n배 = 함수(x: 정수) { 반환 x * 배수 }
출력(형식("3배: {0}", 적용(n배, 7)))
